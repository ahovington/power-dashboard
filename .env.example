# Docker Compose
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=power_monitor
HOST_PORT=80
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Backend Configuration
# Note: use service name 'db' (not localhost) when running via docker compose
DATABASE_URL=postgres://postgres:changeme@db:5432/power_monitor?sslmode=disable
GO_ENV=development
LOG_LEVEL=debug

# Enphase Configuration
# Get your API key from https://developer.enphase.com/
ENPHASE_API_KEY=your_enphase_api_key
ENPHASE_SYSTEM_ID=your_system_id

# Tesla Configuration (future)
# TESLA_API_TOKEN=your_tesla_token
# TESLA_SITE_ID=your_site_id

# Polling
POLL_INTERVAL_SECONDS=300

# Fake / Demo Provider
# Set FAKE_PROVIDER=true to generate synthetic solar+battery data without real credentials.
# FAKE_SEED=0 means non-deterministic (new values each restart); set a fixed integer for
# reproducible data (useful for CI or demos).
FAKE_PROVIDER=false
FAKE_SEED=0

# Frontend Configuration
VITE_API_URL=/api
